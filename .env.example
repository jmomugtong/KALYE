# Database
DATABASE_URL=postgresql+asyncpg://kalye:kalye_dev@localhost:5432/kalye
DATABASE_URL_SYNC=postgresql://kalye:kalye_dev@localhost:5432/kalye

# Redis
REDIS_URL=redis://localhost:6379/0

# Object Storage (MinIO)
MINIO_ENDPOINT=localhost:9000
MINIO_ACCESS_KEY=minioadmin
MINIO_SECRET_KEY=minioadmin
MINIO_SECURE=false
S3_BUCKET_NAME=kalye-images

# Auth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=change-me-in-production
GOOGLE_CLIENT_ID=your-google-oauth-client-id
GOOGLE_CLIENT_SECRET=your-google-oauth-secret
JWT_SECRET_KEY=change-me-in-production
JWT_ALGORITHM=HS256
JWT_EXPIRATION_MINUTES=60

# Maps
MAPBOX_ACCESS_TOKEN=your-mapbox-token

# AI Models (Hugging Face)
HF_TOKEN=
MODEL_CACHE_DIR=/tmp/models

# Ollama (Local LLM)
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4317
JAEGER_UI_URL=http://localhost:16686
PROMETHEUS_PORT=9090

# Feature Flags
ENABLE_VQA=false
ENABLE_RAG_CHAT=true
ENABLE_AUTO_BLUR=true

# Cost Controls
MAX_INFERENCE_JOBS_PER_HOUR=1000
CACHE_TTL_SECONDS=3600

# App
APP_ENV=development
DEBUG=true
API_HOST=0.0.0.0
API_PORT=8000
