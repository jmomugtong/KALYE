FROM postgis/postgis:15-3.3

# Install pgvector extension on top of PostGIS image
RUN apt-get update \
    && apt-get install -y --no-install-recommends \
        build-essential \
        postgresql-server-dev-15 \
        git \
        ca-certificates \
        clang-11 \
        llvm-11-dev \
    && git clone --branch v0.7.4 https://github.com/pgvector/pgvector.git /tmp/pgvector \
    && cd /tmp/pgvector \
    && make \
    && make install \
    && rm -rf /tmp/pgvector \
    && apt-get remove -y build-essential postgresql-server-dev-15 git clang-11 llvm-11-dev \
    && apt-get autoremove -y \
    && rm -rf /var/lib/apt/lists/*
